# ---- PRIVATE / agency data: never upload (everything except the README) ----
private/*
!private/README.md
# ---- PRIVATE internal docs (agency coordination, personnel, status) ----
private_docs/*
!private_docs/README.md
# local machine-specific config (e.g. external NVTA data root)
**/local_config.json
# build artifacts (regenerate with build.sh)
bin/
cmake_build_rel/
*.obj
*.o
# exe copies staged into run folders at runtime (canonical is bin/DTALite.exe)
test_networks/**/DTALite*.exe
nvta_run/**/DTALite*.exe
# nvta_run results are DERIVED FROM PRIVATE agency data -> never upload
nvta_run/results/
# generic kernel outputs that may carry private volumes (regenerate by re-running)
**/link_performance.csv
**/od_performance.csv
**/route_assignment.csv
**/vehicle.csv
**/system_performance.csv
# but keep the small shipped reference outputs under test_networks/{sf,cs}_*
!test_networks/**/lp_*iter.csv
# binary demand caches (regenerate with `dtalite_qa demand-bin`)
**/*.bin
# python cache
**/__pycache__/
*.pyc

# example outputs generated by the ARC walkthrough (regenerate with arc_calibrate.py + run)
examples/**/gmns_calibrated/
examples/**/arc_super_*/
examples/**/results/

# Python build metadata
*.egg-info/
build/
examples/**/gmns_superzone/
examples/**/gmns_identity/
examples/arc_atlanta/arc_skim_*.csv
examples/arc_atlanta/skim_run.log

# native binding build artifacts (built locally via kernel/python/build_native.sh)
pytaplite/_native*.pyd
pytaplite/_native*.so
kernel/python/build/
*.egg-info/
pytaplite/DTALite.dll
pytaplite/libDTALite.so
pytaplite/libDTALite.dylib
